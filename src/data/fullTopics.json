[
  {
    "id": "full-topic-001",
    "text": "大喜利の回答だけ異常に達筆な小学生。なぜそうなった？",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-002",
    "text": "新人アナウンサーが初日からベテラン扱いされた理由とは？",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-003",
    "text": "町内会の会議なのにやたらとラスボス感がある瞬間",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-004",
    "text": "絶対に優しいはずなのに、なぜか誰も逆らえない保育士の特徴",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-005",
    "text": "深夜のコンビニで言われたら一番じわじわ怖いひと言",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-006",
    "text": "桃太郎が鬼退治の前日にだけ見せる妙に現実的な一面",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-007",
    "text": "ニュース速報になるほどではないが地味に日本中がざわつく出来事",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-008",
    "text": "この校長、たぶん朝礼をエンタメだと思っているな。なぜ気づいた？",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-009",
    "text": "宇宙人が地球を侵略するのを一回やめた、しょうもない理由",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-010",
    "text": "プロポーズの空気ではないのに、なぜか成功したひと言",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-011",
    "text": "時代劇にひとつだけ現代の価値観が混ざっていたらどんな場面になる？",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-012",
    "text": "おばあちゃんが急にスタートアップ用語を使い始めた理由",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-013",
    "text": "動物園の人気者がある日突然SNSをやめたそうです。何があった？",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-014",
    "text": "まだ何もしていないのに、会場全体を味方につけた登場の仕方",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-015",
    "text": "RPGの村人にしては事情を知りすぎている人の第一声",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-016",
    "text": "居酒屋のトイレに貼ってあったら逆に気になる注意書き",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-017",
    "text": "スポーツ漫画なのに急に税金の話が始まった。どんな展開？",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-018",
    "text": "この忍者、隠れる気はあるけど隠すセンスがないなと思った理由",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-019",
    "text": "結婚式のスピーチで言ってはいけないのに、妙に聞いてみたい一言",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-020",
    "text": "神様にお願いしたら、想像よりだいぶ事務的に対応された内容",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-021",
    "text": "温泉旅館の女将が裏でだけ見せるロックすぎる一面",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-022",
    "text": "学級委員長がクラスをまとめるために導入した、いらない制度",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-023",
    "text": "この探偵、推理より先に空気を悪くしてしまうなと思った一言",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-024",
    "text": "ファミレスで隣の席から聞こえてきたら二度見する会話",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-025",
    "text": "勇者一行のグループLINE、たぶん今こうなっている",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-026",
    "text": "初デートなのに議事録を取り始めた人。その真意とは？",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-027",
    "text": "世界一平和なクレーム対応。何を言われた？",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-028",
    "text": "野球部の監督が急に哲学者みたいになった試合中のひと言",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-029",
    "text": "絶景スポットで聞きたくないが、妙に具体的すぎる感想",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-030",
    "text": "魔王が採用面接でだけやたら人当たりがいい理由",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-031",
    "text": "このカフェ、店員より常連客のほうが経営に詳しいな。なぜ？",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-032",
    "text": "謝罪会見なのに少しだけ応援したくなってしまう瞬間",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-033",
    "text": "サンタクロースが繁忙期だけ絶対に言わない本音",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-034",
    "text": "旅番組でそのまま使われたら困る、出演者の正直すぎるコメント",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-035",
    "text": "社長のひと言で社員旅行が一気にサバイバルになった理由",
    "authorName": "匿名開発者"
  },
  {
    "id": "full-topic-036",
    "text": "この発明、便利そうに見えて一番使いどころがわからない。何？",
    "authorName": "匿名開発者"
  }
]
